{
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "description": "Legend layout anchored to the full bounding box via frame bounds.",
  "width": 400,
  "height": 200,
  "padding": 5,
  "autosize": "pad",

  "config": {
    "legend": {
      "layout": {
        "frame": "bounds",
        "top": {"anchor": "end"},
        "bottom": {"anchor": "start"},
        "left": {"anchor": "end"},
        "right": {"anchor": "middle"}
      }
    }
  },

  "data": [
    {
      "name": "source",
      "url": "data/cars.json",
      "transform": [
        {
          "type": "filter",
          "expr": "datum['Horsepower'] != null && datum['Miles_per_Gallon'] != null && datum['Origin'] != null"
        }
      ]
    }
  ],

  "scales": [
    {
      "name": "x",
      "type": "linear",
      "round": true,
      "nice": true,
      "zero": true,
      "domain": {"data": "source", "field": "Horsepower"},
      "range": "width"
    },
    {
      "name": "y",
      "type": "linear",
      "round": true,
      "nice": true,
      "zero": true,
      "domain": {"data": "source", "field": "Miles_per_Gallon"},
      "range": "height"
    },
    {
      "name": "color",
      "type": "ordinal",
      "range": {"scheme": "category10"},
      "domain": {"data": "source", "field": "Origin"}
    },
    {
      "name": "size",
      "type": "linear",
      "round": true,
      "nice": false,
      "zero": true,
      "domain": {"data": "source", "field": "Acceleration"},
      "range": [4, 100]
    }
  ],

  "axes": [
    {
      "scale": "x",
      "grid": true,
      "domain": false,
      "orient": "bottom",
      "tickCount": 5,
      "title": "Horsepower"
    },
    {
      "scale": "y",
      "grid": true,
      "domain": false,
      "orient": "left",
      "titlePadding": 5,
      "title": "Miles_per_Gallon"
    },
    {
      "scale": "y",
      "domain": false,
      "orient": "right",
      "titlePadding": 5,
      "title": "Miles_per_Gallon"
    }
  ],

  "legends": [
    {
      "stroke": "color",
      "title": "Origin",
      "orient": "top",
      "direction": "horizontal"
    },
    {
      "fill": "color",
      "title": "Origin",
      "orient": "bottom",
      "direction": "horizontal"
    },
    {
      "size": "size",
      "title": "Acceleration",
      "orient": "left",
      "symbolStrokeColor": "#4682b4",
      "symbolStrokeWidth": 2,
      "symbolOpacity": 0.5,
      "symbolType": "circle"
    },
    {
      "stroke": "color",
      "title": "Origin",
      "orient": "right"
    }
  ],

  "marks": [
    {
      "name": "marks",
      "type": "symbol",
      "from": {"data": "source"},
      "encode": {
        "update": {
          "x": {"scale": "x", "field": "Horsepower"},
          "y": {"scale": "y", "field": "Miles_per_Gallon"},
          "size": {"scale": "size", "field": "Acceleration"},
          "shape": {"value": "circle"},
          "strokeWidth": {"value": 2},
          "opacity": {"value": 0.5},
          "stroke": {"scale": "color", "field": "Origin"},
          "fill": {"value": "transparent"}
        }
      }
    }
  ]
}
