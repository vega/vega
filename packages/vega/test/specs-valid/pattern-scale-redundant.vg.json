{
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "description": "Accessibility flagship: redundant color+pattern encoding. Each bar's category is encoded twice over -- once by pattern shape, once by foreground color -- so the chart reads correctly in grayscale (pattern alone distinguishes categories) while still offering color for readers who can use it. The range is a literal array of fully-specified pattern wrappers (name + foreground) rather than a signal-composed scheme('patterns')/scheme('tableau10') pairing: the expression language exposes scale()/scale name references but no scheme() accessor to combine two named schemes element-wise in spec-land, so the foreground colors below are the first five vega-scale 'tableau10' values, applied by hand, one per named pattern.",
  "width": 260,
  "height": 200,
  "padding": 5,
  "data": [
    {
      "name": "table",
      "values": [
        {"category": "A", "value": 28},
        {"category": "B", "value": 55},
        {"category": "C", "value": 43},
        {"category": "D", "value": 19},
        {"category": "E", "value": 37}
      ]
    }
  ],
  "scales": [
    {
      "name": "xscale",
      "type": "band",
      "domain": {"data": "table", "field": "category"},
      "range": "width",
      "padding": 0.2
    },
    {
      "name": "yscale",
      "type": "linear",
      "domain": {"data": "table", "field": "value"},
      "range": "height",
      "nice": true
    },
    {
      "name": "patternColor",
      "type": "ordinal",
      "domain": {"data": "table", "field": "category"},
      "range": [
        {"pattern": {"name": "diagonal-stripe", "foreground": "#4c78a8"}},
        {"pattern": {"name": "circles", "foreground": "#f58518"}},
        {"pattern": {"name": "crosshatch", "foreground": "#e45756"}},
        {"pattern": {"name": "vertical-stripe", "foreground": "#72b7b2"}},
        {"pattern": {"name": "grid", "foreground": "#54a24b"}}
      ]
    }
  ],
  "legends": [
    {"fill": "patternColor", "title": "Category", "orient": "right"}
  ],
  "marks": [
    {
      "type": "rect",
      "from": {"data": "table"},
      "encode": {
        "enter": {
          "x": {"scale": "xscale", "field": "category"},
          "width": {"scale": "xscale", "band": 1},
          "y": {"scale": "yscale", "field": "value"},
          "y2": {"scale": "yscale", "value": 0},
          "stroke": {"value": "#333"}
        },
        "update": {
          "fill": {"scale": "patternColor", "field": "category"}
        }
      }
    }
  ]
}
