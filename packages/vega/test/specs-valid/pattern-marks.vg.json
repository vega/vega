    {
      "name": "barY",
      "type": "linear",
      "domain": {
        "data": "barData",
        "field": "v"
      },
      "range": [
        120,
        0
      ],
      "nice": true
    },
    {
      "name": "areaX",
      "type": "linear",
      "domain": {
        "data": "areaData",
        "field": "t"
      },
      "range": [
