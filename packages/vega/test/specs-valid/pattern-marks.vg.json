{
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "description": "Pattern fill consistency across mark types and small charts.",
  "width": 900,
  "height": 550,
  "padding": 5,
  "signals": [
    {
      "name": "patternNames",
      "value": [
        "diagonal-stripe",
        "horizontal-stripe",
        "vertical-stripe",
        "caps",
        "circles",
        "crosses",
        "crosshatch",
        "grid",
        "houndstooth",
        "nylon",
        "squares",
        "waves",
        "woven"
      ]
    },
    {
      "name": "patternName",
      "value": "diagonal-stripe",
      "bind": {
        "input": "select",
        "name": "pattern",
        "options": [
          "diagonal-stripe",
          "horizontal-stripe",
          "vertical-stripe",
          "caps",
          "circles",
          "crosses",
          "crosshatch",
          "grid",
          "houndstooth",
          "nylon",
          "squares",
          "waves",
          "woven"
        ]
      }
    },
    {
      "name": "patternOrigin",
      "value": "view",
      "bind": {
        "input": "select",
        "name": "origin",
        "options": [
          "view",
          "mark"
        ]
      }
    },
    {
      "name": "pat",
      "update": "{pattern:{name:patternName, origin: patternOrigin}}"
    }
  ],
  "data": [
    {
      "name": "single",
      "values": [
        1
      ]
    },
    {
