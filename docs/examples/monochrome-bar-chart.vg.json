{
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "description": "A bar chart using the built-in 'monochrome' pattern scheme, a print-friendly palette that interleaves solid greyscale values with texture fills.",
  "width": 400,
  "height": 200,
  "padding": 5,

  "data": [
    {
      "name": "table",
      "values": [
        {"category": "A", "amount": 28},
        {"category": "B", "amount": 55},
        {"category": "C", "amount": 43},
        {"category": "D", "amount": 91},
        {"category": "E", "amount": 81},
        {"category": "F", "amount": 53}
      ]
    }
  ],

  "scales": [
    {
      "name": "xscale",
      "type": "band",
      "domain": {"data": "table", "field": "category"},
      "range": "width",
      "padding": 0.15,
      "round": true
    },
    {
      "name": "yscale",
      "domain": {"data": "table", "field": "amount"},
      "nice": true,
      "range": "height"
    },
    {
      "name": "fill",
      "type": "ordinal",
      "domain": {"data": "table", "field": "category"},
      "range": {"scheme": "monochrome"}
    }
  ],

  "axes": [
    { "orient": "bottom", "scale": "xscale" },
    { "orient": "left", "scale": "yscale" }
  ],

  "legends": [
    {
      "fill": "fill",
      "title": "Category",
      "encode": {
        "symbols": {
          "update": {
            "stroke": {"value": "#333"},
            "strokeWidth": {"value": 0.5}
          }
        }
      }
    }
  ],

  "marks": [
    {
      "type": "rect",
      "from": {"data": "table"},
      "encode": {
        "enter": {
          "x": {"scale": "xscale", "field": "category"},
          "width": {"scale": "xscale", "band": 1},
          "y": {"scale": "yscale", "field": "amount"},
          "y2": {"scale": "yscale", "value": 0},
          "stroke": {"value": "#000"},
          "strokeWidth": {"value": 1}
        },
        "update": {
          "fill": {"scale": "fill", "field": "category"}
        }
      }
    }
  ]
}
