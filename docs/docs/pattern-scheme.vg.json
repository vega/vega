{
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "description": "Swatches for the built-in 'patterns' scheme, in scheme order.",
  "width": 540,
  "height": 190,
  "padding": 5,

  "data": [
    {
      "name": "patterns",
      "values": [
        {"i": 0, "name": "diagonal-stripe"},
        {"i": 1, "name": "circles"},
        {"i": 2, "name": "crosshatch"},
        {"i": 3, "name": "vertical-stripe"},
        {"i": 4, "name": "squares"},
        {"i": 5, "name": "horizontal-stripe"},
        {"i": 6, "name": "crosses"},
        {"i": 7, "name": "grid"},
        {"i": 8, "name": "caps"},
        {"i": 9, "name": "waves"}
      ],
      "transform": [
        {"type": "formula", "as": "col", "expr": "datum.i % 5"},
        {"type": "formula", "as": "row", "expr": "floor(datum.i / 5)"}
      ]
    }
  ],

  "scales": [
    {
      "name": "x",
      "type": "band",
      "domain": [0, 1, 2, 3, 4],
      "range": [0, 540]
    },
    {
      "name": "y",
      "type": "band",
      "domain": [0, 1],
      "range": [0, 190]
    },
    {
      "name": "tex",
      "type": "ordinal",
      "domain": {"data": "patterns", "field": "name"},
      "range": {"scheme": "patterns"}
    }
  ],

  "marks": [
    {
      "type": "rect",
      "from": {"data": "patterns"},
      "encode": {
        "enter": {
          "x": {"scale": "x", "field": "col", "offset": 22},
          "y": {"scale": "y", "field": "row", "offset": 2},
          "width": {"value": 64},
          "height": {"value": 64},
          "fill": {"scale": "tex", "field": "name"},
          "stroke": {"value": "#ccc"}
        }
      }
    },
    {
      "type": "text",
      "from": {"data": "patterns"},
      "encode": {
        "enter": {
          "x": {"scale": "x", "field": "col", "offset": 54},
          "y": {"scale": "y", "field": "row", "offset": 80},
          "text": {"field": "name"},
          "align": {"value": "center"},
          "fontSize": {"value": 11},
          "fill": {"value": "#4682b4"}
        }
      }
    }
  ]
}
